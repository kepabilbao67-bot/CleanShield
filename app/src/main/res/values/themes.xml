<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CleanShield" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary -->
        <item name="android:colorPrimary">@color/primary</item>
        <item name="android:colorPrimaryDark">@color/primary_dark</item>
        <item name="android:colorAccent">@color/secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_light</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.CleanShield.Blocked" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">@color/blocked_red</item>
        <item name="android:colorPrimaryDark">@color/blocked_red_dark</item>
        <item name="android:colorAccent">@color/blocked_red_light</item>
        <item name="android:colorBackground">@color/blocked_red_dark</item>
        <item name="android:statusBarColor">@color/blocked_red_dark</item>
        <item name="android:navigationBarColor">@color/blocked_red_dark</item>
    </style>
</resources>
